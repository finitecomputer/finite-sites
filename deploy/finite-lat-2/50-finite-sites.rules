// Install as /etc/polkit-1/rules.d/50-finite-sites.rules.
// finitesitesd (user finite-sites) manages tier-2 app units over D-Bus;
// instance names are platform-generated site ids, never user input.
polkit.addRule(function (action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "finite-sites") {
        var unit = action.lookup("unit");
        if (unit && unit.indexOf("finite-app@") == 0) {
            return polkit.Result.YES;
        }
    }
});
